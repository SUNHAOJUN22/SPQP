{
  "name": "sio-catalyst-quantum-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack quantum-chemical research cockpit for Si-O functional alpha-olefin Ziegler-Natta workflows.",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "install:all": "npm --prefix frontend install",
    "test:backend": "cd backend && .venv\\Scripts\\python.exe -m pytest",
    "test:coverage": "cd backend && .venv\\Scripts\\python.exe -m pytest --cov=app --cov-report=term-missing",
    "test:ui-smoke": "node scripts\\ui_smoke_check.mjs",
    "audit:mojibake": "python scripts\\mojibake_audit.py --fail-on-active",
    "test:ultra": "backend\\.venv\\Scripts\\python.exe scripts\\ultra_quality_audit.py",
    "test": "npm run test:backend && npm --prefix frontend run test",
    "test:ci": "npm run test:coverage && npm --prefix frontend run test && npm run typecheck && npm run lint && backend\\.venv\\Scripts\\python.exe scripts\\scientific_rigor_audit.py && backend\\.venv\\Scripts\\python.exe scripts\\full_function_smoke.py && npm run test:ultra && npm run build",
    "test:e2e": "npm run test:ui-smoke",
    "lint": "npm run lint:frontend",
    "typecheck": "npm run typecheck:frontend",
    "build": "npm --prefix frontend run build",
    "examples:external-qc": "backend\\.venv\\Scripts\\python.exe scripts\\run_external_qc_examples.py --check-only",
    "lint:frontend": "npm --prefix frontend run lint",
    "typecheck:frontend": "npm --prefix frontend run typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
