"use client";

import { useEffect, useMemo, useState } from "react";
import { motion } from "framer-motion";
import {
  Boxes,
  CheckCircle2,
  Cpu,
  Database,
  FileCode2,
  FolderTree,
  GitMerge,
  LayoutDashboard,
  Network,
  ShieldCheck
} from "lucide-react";
import {
  Bar,
  BarChart,
  CartesianGrid,
  Cell,
  ResponsiveContainer,
  Tooltip,
  XAxis,
  YAxis
} from "recharts";
import { Card, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { StatusBadge } from "@/components/ui/status-badge";
import { Button } from "@/components/ui/button";

import { useStudio } from "@/lib/store";

const API_BASE = process.env.NEXT_PUBLIC_API_BASE_URL ?? "http://localhost:8000/api";

type SourceMap = {
  status: string;
  strategy: string;
  backend_integrated: string[];
  frontend_integrated: string[];
  docs_integrated: string[];
  dismantled_source_locations?: Record<string, string>;
  active_rule: string;
};

type TaskGroups = {
  groups: Record<string, { id: string; title: string }[]>;
  total_tasks: number;
  provenance: string;
};

const assetStats = [
  { name: "еүҚз«ҜжқҘжәҗ", files: 41295, sizeMb: 1142.6, tone: "cyan" },
  { name: "еҗҺз«ҜжқҘжәҗ", files: 48, sizeMb: 0.38, tone: "violet" },
  { name: "и„ҡжң¬е·Ҙе…·", files: 43, sizeMb: 0.09, tone: "orange" },
  { name: "ж–ҮжЎЈиө„дә§", files: 10, sizeMb: 0.02, tone: "green" },
  { name: "йғЁзҪІж–Үд»¶", files: 10, sizeMb: 0.01, tone: "blue" },
  { name: "еӣҫеғҸ/PDF", files: 8, sizeMb: 1.56, tone: "yellow" }
];

const appModules = [
  { title: "и®әж–Үй©ұеҠЁзҹҘиҜҶеә?, detail: "еҚҡеЈ«и®әж–Үе®һдҪ“жҠҪеҸ–гҖҒеҚ•дҪ“ж—ҸгҖҒеӮ¬еҢ–еүӮжЁЎеһӢгҖҒе®һйӘҢдҪ“зі»гҖ?, icon: Database },
  { title: "Gaussian 36 д»»еҠЎжЁЎжқҝ", detail: "еҚ•дҪ“гҖҒTEAгҖҒTi й…ҚдҪҚгҖҒжҸ’е…?TSгҖҒеҗҺеҸҚеә”гҖҒutility ж–Үжң¬з”ҹжҲҗгҖ?, icon: FileCode2 },
  { title: "йҮҸеӯҗжңәзҗҶй©ҫй©¶иҲ?, detail: "О”GpoisonгҖҒО”GвҖЎгҖҒkrelгҖҒеӣӣиҪҙеҲӨжҚ®дёҺеҸҜиҜҒдјӘжңәеҲ¶жЁЎеһӢгҖ?, icon: LayoutDashboard },
  { title: "еҲҶеӯҗжҷәиғҪиҜҶеҲ«", detail: "SiгҖҒOMe ж°§гҖҒSiвҖ“ClгҖҒC=CгҖҒAlгҖҒTi жҙ»жҖ§дҪҚзӮ№иҮӘеҠЁиҜҶеҲ«гҖ?, icon: Network },
  { title: "й«ҳзә§з§‘еӯҰжү©еұ•", detail: "WignerгҖҒBoltzmannгҖҒGPR/EIгҖҒVMCгҖҒеҗҺеҸҚеә”еҠЁеҠӣеӯҰгҖ?, icon: Cpu },
  { title: "дёӯж–Үз§‘з ”жҠҘе‘Ҡ", detail: "еҢәеҲҶи®әж–ҮжҠҪеҸ–гҖҒзңҹе®һдёҠдј гҖҒз”ЁжҲ·иҫ“е…Ҙе’ҢзӨәдҫӢж•°жҚ®гҖ?, icon: ShieldCheck }
];

function ChartTooltip() {
  return (
    <Tooltip
      contentStyle={{
        background: "hsl(var(--studio-panel))",
        border: "1px solid hsl(var(--studio-line))",
        borderRadius: 18,
        color: "hsl(var(--studio-text))"
      }}
      labelStyle={{ color: "hsl(var(--studio-text))" }}
    />
  );
}

export function IntegratedHomePanel() {
  const { backendStatus } = useStudio();
  const [sourceMap, setSourceMap] = useState<SourceMap | null>(null);
  const [taskGroups, setTaskGroups] = useState<TaskGroups | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [clock, setClock] = useState(() => new Date().toLocaleTimeString("zh-CN"));

  useEffect(() => {
    void refresh();
    const timer = setInterval(() => setClock(new Date().toLocaleTimeString("zh-CN")), 1000);
    return () => clearInterval(timer);
  }, []);

  const taskGroupRows = useMemo(() => {
    if (!taskGroups) return [];
    return Object.entries(taskGroups.groups).map(([group, items]) => ({
      group,
      count: items.length,
      title: groupTitle(group)
    }));
  }, [taskGroups]);

  async function refresh() {
    setError(null);
    try {
      const [sourceResponse, taskResponse] = await Promise.all([
        fetch(`${API_BASE}/integration/source-map`),
        fetch(`${API_BASE}/integration/gaussian-task-groups`)
      ]);
      if (!sourceResponse.ok || !taskResponse.ok) throw new Error("ж•ҙеҗҲзҠ¶жҖ?API иҜ»еҸ–еӨұиҙҘгҖ?);
      setSourceMap((await sourceResponse.json()) as SourceMap);
      setTaskGroups((await taskResponse.json()) as TaskGroups);
    } catch (cause) {
      setError(cause instanceof Error ? cause.message : "ж•ҙеҗҲзҠ¶жҖҒиҜ»еҸ–еӨұиҙҘгҖ?);
    }
  }

  return (
    <div className="space-y-4">
      {/* зі»з»ҹиҝҗиЎҢзҠ¶жҖ?*/}
      <div className="grid gap-3 md:grid-cols-4">
        {[
          { label: "еҪ“еүҚж—¶й—ҙ", value: clock, icon: "рҹ•җ" },
          { label: "еҗҺз«ҜзҠ¶жҖ?, value: backendStatus === "connected" ? "е·ІиҝһжҺ?вң? : backendStatus === "checking" ? "жЈҖжөӢдёӯвҖ? : "жңӘиҝһжҺ?вқ?, icon: "рҹ”—" },
          { label: "еҠҹиғҪжЁЎеқ—", value: "23 дё?, icon: "рҹ“Ұ" },
          { label: "ж•°жҚ®жқҘжәҗ", value: "зӨәдҫӢж•°жҚ®", icon: "вҡ пёҸ" },
        ].map((card) => (
          <div key={card.label} className="border border-studio-line/60 bg-studio-panel rounded-xl p-4">
            <div className="flex items-center gap-2 text-xs text-studio-muted">
              <span>{card.icon}</span>
              <span>{card.label}</span>
            </div>
            <p className="mt-2 text-lg font-medium">{card.value}</p>
          </div>
        ))}
      </div>
      <Card className="relative overflow-hidden p-6">

        <div className="relative grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
          <div>
            <StatusBadge tone="green">ж•ҙеҗҲзүҲж–°еә”з”Ё</StatusBadge>
            <h2 className="mt-5 max-w-5xl text-4xl font-semibold tracking-normal md:text-6xl">
              зЎ…ж°§й”®еӮ¬еҢ–йҮҸеӯҗз ”з©¶е№іеҸ?V3
            </h2>
            <p className="mt-3 text-sm font-medium text-studio-muted">SiO Catalyst Quantum Studio Pro Integrated</p>
            <p className="mt-5 max-w-4xl text-base leading-8 text-studio-muted">
              еҺ?`Si-O` зӢ¬з«ӢеӯҗйЎ№зӣ®е·Із»ҸжӢҶж•Је№¶еҪ’е…ҘеҪ“еүҚж №е·ҘдҪңзӣ®еҪ•гҖӮзҺ°еңЁеүҚз«ҜгҖҒеҗҺз«ҜгҖҒи„ҡжң¬гҖҒж–ҮжЎЈе’Ңиө„дә§з”ұеҗҢдёҖдёӘеә”з”Ёз»ҹзӯ№пјҡ
              дёӯж–Үз§‘з ”з•ҢйқўгҖҒGaussian жЁЎжқҝгҖҒи®әж–ҮзҹҘиҜҶеә“гҖҒе®һйӘ?DFT еҜ№з…§гҖҒеҲҶеӯҗжҷәиғҪиҜҶеҲ«е’ҢжңәзҗҶеҲӨжҚ®еңЁеҗҢдёҖе·ҘдҪңжөҒеҶ…иҝҗиЎҢгҖ?            </p>
            <div className="mt-7 flex flex-wrap gap-3">
              <Button onClick={refresh} icon={<GitMerge className="h-4 w-4" />}>еҲ·ж–°ж•ҙеҗҲзҠ¶жҖ?/Button>
              <StatusBadge tone="blue">е”ҜдёҖиҝҗиЎҢзӣ®еҪ•пјҡD:\codex2_cataSi-O</StatusBadge>
              <StatusBadge tone="gray">зӢ¬з«Ӣ Si-O ж–Үд»¶еӨ№е·Із§»йҷӨ</StatusBadge>
            </div>
          </div>
          <Card className="bg-studio-panel/70">
            <CardHeader>
              <div>
                <CardTitle>жӢҶи§ЈзҠ¶жҖ?/CardTitle>
                <CardDescription>еҺҹеӯҗйЎ№зӣ®дёҚеҶҚдҪңдёәзӢ¬з«Ӣеә”з”ЁеӯҳеңЁ</CardDescription>
              </div>
              <CheckCircle2 className="h-5 w-5 text-studio-green" />
            </CardHeader>
            <p className="text-lg font-semibold text-studio-text">{sourceMap?.status ?? "жӯЈеңЁиҜ»еҸ–ж•ҙеҗҲжәҗеӣҫвҖ?}</p>
            <p className="mt-4 text-sm leading-7 text-studio-muted">
              {sourceMap?.strategy ?? "жӯЈеңЁд»Һж №йЎ№зӣ® API иҺ·еҸ–жӢҶи§ЈдёҺж•ҙеҗҲзӯ–з•ҘгҖ?}
            </p>
            {error ? <p className="mt-4 text-sm font-semibold text-studio-red">{error}</p> : null}
          </Card>
        </div>
      </Card>

      <div className="grid gap-4 xl:grid-cols-[1fr_0.9fr]">
        <Card>
          <CardHeader>
            <div>
              <CardTitle>жӢҶи§Јиө„дә§еҲҶеёғ</CardTitle>
              <CardDescription>жүҖжңүжқҘжәҗж–Үд»¶е·Іиҝӣе…Ҙж №зӣ®еҪ?`integrated/origin-*` еҲҶзұ»иө„дә§еә?/CardDescription>
            </div>
            <FolderTree className="h-5 w-5 text-studio-cyan" />
          </CardHeader>
          <div className="h-80">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={assetStats}>
                <CartesianGrid stroke="hsl(var(--studio-line))" strokeDasharray="3 6" />
                <XAxis dataKey="name" tick={{ fill: "hsl(var(--studio-muted))", fontSize: 12 }} />
                <YAxis tick={{ fill: "hsl(var(--studio-muted))", fontSize: 12 }} />
                <ChartTooltip />
                <Bar dataKey="files" name="ж–Үд»¶ж•? radius={[12, 12, 0, 0]}>
                  {assetStats.map((row) => (
                    <Cell key={row.name} fill={`hsl(var(--studio-${row.tone}))`} />
                  ))}
                </Bar>
              </BarChart>
            </ResponsiveContainer>
          </div>
        </Card>

        <Card>
          <CardHeader>
            <div>
              <CardTitle>Gaussian д»»еҠЎе®Үе®ҷ</CardTitle>
              <CardDescription>36 зұ»жЁЎжқҝе·Іиҝӣе…Ҙж №йЎ№зӣ®еҗҺз«ҜжңҚеҠ?/CardDescription>
            </div>
            <StatusBadge tone="violet">{taskGroups?.total_tasks ?? 36} дёӘд»»еҠ?/StatusBadge>
          </CardHeader>
          <div className="grid gap-3 md:grid-cols-2">
            {(taskGroupRows.length ? taskGroupRows : fallbackTaskGroups()).map((row) => (
              <div key={row.group} className="rounded-xl border border-studio-line bg-studio-panel2/70 p-4">
                <div className="flex items-center justify-between">
                  <p className="font-medium text-studio-text">{row.title}</p>
                  <StatusBadge tone="blue">{row.count}</StatusBadge>
                </div>
                <p className="mt-2 text-xs font-medium text-studio-muted">Group {row.group}</p>
              </div>
            ))}
          </div>
          <p className="mt-4 text-sm leading-7 text-studio-muted">
            {taskGroups?.provenance ?? "иҝҷдәӣжЁЎжқҝеҸӘз”ҹжҲ?Gaussian / utility ж–Үжң¬пјҢдёҚдјҡжү§иЎ?GaussianгҖҒcubegen жҲ?MultiwfnгҖ?}
          </p>
        </Card>
      </div>

      <div className="grid gap-4 xl:grid-cols-3">
        {appModules.map((module) => {
          const Icon = module.icon;
          return (
            <motion.div key={module.title} >
              <Card className="h-full min-h-[210px]">
                <div className="grid h-12 w-12 place-items-center rounded-xl bg-studio-cyan/15 text-studio-cyan">
                  <Icon className="h-5 w-5" />
                </div>
                <h3 className="mt-5 text-lg font-medium text-studio-text">{module.title}</h3>
                <p className="mt-3 text-sm leading-7 text-studio-muted">{module.detail}</p>
              </Card>
            </motion.div>
          );
        })}
      </div>

      <Card>
        <CardHeader>
          <div>
            <CardTitle>ж №зӣ®еҪ•жҙ»еҠЁи§„еҲ?/CardTitle>
            <CardDescription>еҗҺз»ӯејҖеҸ‘еҸӘйқўеҗ‘ж•ҙеҗҲеҗҺзҡ„еә”з”Ё</CardDescription>
          </div>
          <Boxes className="h-5 w-5 text-studio-orange" />
        </CardHeader>
        <p className="text-sm leading-7 text-studio-muted">
          {sourceMap?.active_rule ??
            "еҗҺз»ӯејҖеҸ‘гҖҒжөӢиҜ•е’ҢеҗҜеҠЁйғҪеңЁж №зӣ®еҪ?D:\\codex2_cataSi-O еҶ…е®ҢжҲҗпјӣжӢҶи§ЈжқҘжәҗд»…дҪңдё?integrated/origin-* еҲҶзұ»иө„дә§дҝқз•ҷгҖ?}
        </p>
        <div className="mt-4 grid gap-3 md:grid-cols-3">
          {Object.entries(sourceMap?.dismantled_source_locations ?? fallbackLocations()).map(([key, value]) => (
            <div key={key} className="rounded-xl border border-studio-line bg-studio-panel2/70 p-3">
              <p className="text-xs font-medium uppercase text-studio-muted">{key}</p>
              <p className="mt-2 text-sm font-medium text-studio-text">{value}</p>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

function groupTitle(group: string) {
  const map: Record<string, string> = {
    A: "еҚ•дҪ“дёҺй”®",
    B: "еӮ¬еҢ–еү?еҠ©еүӮ",
    C: "жҸ’е…ҘеҸҚеә”",
    D: "ж°ҙи§Јзј©еҗҲ",
    E: "иҮӘз”ұеҹәеҗҺеҸҚеә”",
    F: "еҸҜи§ҶеҢ–е·Ҙе…?
  };
  return map[group] ?? `д»»еҠЎз»?${group}`;
}

function fallbackTaskGroups() {
  return ["A", "B", "C", "D", "E", "F"].map((group) => ({ group, title: groupTitle(group), count: 6 }));
}

function fallbackLocations() {
  return {
    frontend: "integrated/origin-frontend",
    backend: "integrated/origin-backend",
    docs: "integrated/origin-docs",
    scripts: "integrated/origin-scripts",
    deployment: "integrated/origin-deployment",
    assets: "integrated/origin-assets"
  };
}
